>\r\n      <div className=\"bg-white rounded-xl shadow-2xl max-w-2xl w-full p-8 border-t-4 border-red-500\">\r\n        {/* Header */}\r\n        <div className=\"flex items-start gap-4\">\r\n          <div className=\"flex-shrink-0\">\r\n            <AlertTriangle className=\"h-8 w-8 text-red-600 mt-1\" />\r\n          </div>\r\n          <div className=\"flex-1\">\r\n            <h1 className=\"text-2xl font-bold text-red-900\">\r\n              Oups ! Quelque chose s'est mal pass├®\r\n            </h1>\r\n            <p className=\"mt-2 text-red-700\">\r\n              L'application a rencontr├® une erreur inattendue. Nos ├®quipes\r\n              techniques ont ├®t├® notifi├®es.\r\n            </p>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Error Details */}\r\n        <div className=\"mt-6 bg-red-50 rounded-lg p-4 border border-red-200\">\r\n          <p className=\"text-sm font-mono text-red-800\">\r\n            <strong>Erreur:</strong> {error.message || \"Erreur inconnue\"}\r\n          </p>\r\n          {error.name && (\r\n            <p className=\"text-sm font-mono text-red-700 mt-1\">\r\n              <strong>Type:</strong> {error.name}\r\n            </p>\r\n          )}\r\n        </div>\r\n\r\n        {/* Stack Trace (Dev Only) */}\r\n        {import.meta.env.DEV && errorInfo && (\r\n          <div className=\"mt-4\">\r\n            <button\r\n              onClick={() => setShowStack(!showStack)}\r\n              className=\"flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 transition-colors\"\r\n              type=\"button\"\r\n            >\r\n              <ChevronDown\r\n                size={16}\r\n                className={`transform transition-transform ${\r\n                  showStack ? \"rotate-180\" : \"\"\r\n                }`}\r\n              />\r\n              {showStack ? \"Masquer\" : \"Afficher\"} les d├®tails techniques\r\n            </button>\r\n\r\n            {showStack && (\r\n              <pre className=\"mt-3 bg-gray-900 text-gray-100 p-4 rounded-lg overflow-auto max-h-64 text-xs\">\r\n                {errorInfo.componentStack}\r\n              </pre>\r\n            )}\r\n          </div>\r\n        )}\r\n\r\n        {/* Actions */}\r\n        <div className=\"mt-8 flex flex-col gap-3\">\r\n          <button\r\n            onClick={resetErrorBoundary}\r\n            className=\"flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors\"\r\n            type=\"button\"\r\n          >\r\n            <RotateCcw size={18} />\r\n            R├®essayer\r\n          </button>\r\n\r\n          {import.meta.env.DEV && (\r\n            <button\r\n              onClick={handleExportLogs}\r\n              disabled={exportLoading}\r\n              className=\"flex items-center justify-center gap-2 bg-gray-200 hover:bg-gray-300 disabled:bg-gray-100 disabled:cursor-not-allowed text-gray-800 font-semibold py-2 px-6 rounded-lg transition-colors\"\r\n              type=\"button\"\r\n            >\r\n              {exportLoading ? \"Exportation...\" : \"Exporter les logs\"}\r\n            </button>\r\n          )}\r\n\r\n          <button\r\n            onClick={() => (window.location.href = \"/\")}\r\n            className=\"text-center text-gray-600 hover:text-gray-900 font-semibold py-2 px-6 rounded-lg border border-gray-300 hover:border-gray-400 transition-colors\"\r\n            type=\"button\"\r\n          >\r\n            Retourner ├á l'accueil\r\n          </button>\r\n        </div>\r\n\r\n        {/* Additional Info */}\r\n        <div className=\"mt-8 pt-6 border-t border-gray-200\">\r\n          <details className=\"text-sm text-gray-600\">\r\n            <summary className=\"cursor-pointer font-semibold hover:text-gray-900\">\r\n              ­ƒÆí Comment puis-je vous aider ?\r\n            </summary>\r\n            <ul className=\"mt-3 space-y-2 ml-4\">\r\n              <li className=\"list-disc\">V├®rifiez votre connexion Internet</li>\r\n              <li className=\"list-disc\">\r\n                Videz le cache de votre navigateur{\" \"}\r\n                <code className=\"bg-gray-100 px-1 rounded\">\r\n                  Ctrl+Shift+Delete\r\n                </code>\r\n              </li>\r\n              <li className=\"list-disc\">\r\n                Essayez d'autre navigateur (Chrome, Firefox, Edge)\r\n              </li>\r\n              <li className=\"list-disc\">\r\n                Contactez{\" \"}\r\n                <a\r\n                  href=\"mailto:support@micro-gestion.fr\"\r\n                  className=\"text-blue-600 hover:text-blue-700 underline\"\r\n                >\r\n                  support@micro-gestion.fr\r\n                </a>\r\n              </li>\r\n            </ul>\r\n          </details>\r\n        </div>\r\n\r\n        {/* Error ID for tracking */}\r\n        <div className=\"mt-6 text-center text-xs text-gray-400\">\r\n          ID Erreur: {Date.now()}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default ErrorFallback;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Thomas\\Micro-Gestion-Facile\\src\\components\\ExportModal.tsx","messages":[{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":319,"column":23,"messageId":"voidReturnAttribute","endLine":319,"endColumn":37}],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":99,"column":23,"messageId":"unexpectedAny","endLine":99,"endColumn":26,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3069,3072],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3069,3072],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * ExportModal ÔÇö Modal d'export complet des donn├®es\r\n * ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\r\n * Permet ├á l'utilisateur d'exporter ses donn├®es au format JSON ou CSV.\r\n * Conformit├® RGPD Art. 20 (droit ├á la portabilit├® des donn├®es).\r\n *\r\n * Formats :\r\n *   - JSON : export complet avec toutes les collections (backup complet)\r\n *   - CSV  : export par collection (compatible Excel/OpenOffice)\r\n */\r\n\r\nimport { Archive, Check, Download, FileBraces as FileJson, FileSpreadsheet, X } from 'lucide-react';\r\nimport React, { useState } from 'react';\r\nimport { toast } from 'sonner';\r\nimport {\r\n  downloadFile,\r\n  exportAsCSV,\r\n  exportAsJSON,\r\n  generateFilename,\r\n  type ExportData,\r\n} from '../lib/exportUtils';\r\n\r\n// ÔöÇÔöÇÔöÇ Types ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\r\n\r\ntype ExportFormat = 'json' | 'csv';\r\n\r\ntype CollectionKey = Exclude<keyof ExportData, 'version' | 'exportedAt' | 'userProfile'>;\r\n\r\nconst COLLECTION_LABELS: Record<CollectionKey, string> = {\r\n  invoices: 'Factures & devis',\r\n  clients: 'Clients',\r\n  suppliers: 'Fournisseurs',\r\n  products: 'Produits & services',\r\n  expenses: 'D├®penses',\r\n  emails: 'Emails',\r\n  emailTemplates: \"Mod├¿les d'email\",\r\n  calendarEvents: '├ëv├®nements calendrier',\r\n};\r\n\r\nconst CSV_COLLECTION_KEYS: CollectionKey[] = [\r\n  'invoices',\r\n  'clients',\r\n  'suppliers',\r\n  'products',\r\n  'expenses',\r\n];\r\n\r\nexport interface ExportModalProps {\r\n  isOpen: boolean;\r\n  onClose: () => void;\r\n  data: ExportData;\r\n}\r\n\r\n// ÔöÇÔöÇÔöÇ Composant ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\r\n\r\nconst ExportModal: React.FC<ExportModalProps> = ({ isOpen, onClose, data }) => {\r\n  const [format, setFormat] = useState<ExportFormat>('json');\r\n  const [selectedCollections, setSelectedCollections] = useState<Set<CollectionKey>>(\r\n    new Set(Object.keys(COLLECTION_LABELS) as CollectionKey[])\r\n  );\r\n  const [isExporting, setIsExporting] = useState(false);\r\n\r\n  if (!isOpen) {\r\n    return null;\r\n  }\r\n\r\n  // ÔöÇÔöÇÔöÇ Handlers ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\r\n\r\n  const toggleCollection = (key: CollectionKey) => {\r\n    setSelectedCollections((prev) => {\r\n      const next = new Set(prev);\r\n      if (next.has(key)) {\r\n        next.delete(key);\r\n      } else {\r\n        next.add(key);\r\n      }\r\n      return next;\r\n    });\r\n  };\r\n\r\n  const selectAll = () =>\r\n    setSelectedCollections(new Set(Object.keys(COLLECTION_LABELS) as CollectionKey[]));\r\n\r\n  const deselectAll = () => setSelectedCollections(new Set());\r\n\r\n  const handleExport = async () => {\r\n    if (selectedCollections.size === 0) {\r\n      toast.warning('S├®lectionnez au moins une collection ├á exporter.');\r\n      return;\r\n    }\r\n\r\n    setIsExporting(true);\r\n    try {\r\n      if (format === 'json') {\r\n        // Export complet JSON avec les collections s├®lectionn├®es\r\n        const partial: Partial<ExportData> = { userProfile: data.userProfile };\r\n        for (const key of selectedCollections) {\r\n          // eslint-disable-next-line @typescript-eslint/no-explicit-any\r\n          (partial as any)[key] = data[key];\r\n        }\r\n        const json = await exportAsJSON(partial);\r\n        downloadFile(json, generateFilename('backup', 'json'), 'application/json');\r\n        toast.success('Export JSON t├®l├®charg├® avec succ├¿s');\r\n      } else {\r\n        // Export CSV par collection (une par fichier)\r\n        const csvKeys = CSV_COLLECTION_KEYS.filter((k) => selectedCollections.has(k));\r\n        if (csvKeys.length === 0) {\r\n          toast.warning(\r\n            'Le format CSV ne supporte que : factures, clients, fournisseurs, produits, d├®penses.'\r\n          );\r\n          return;\r\n        }\r\n        for (const key of csvKeys) {\r\n          const rows = data[key] as unknown[];\r\n          if (rows.length === 0) {\r\n            continue;\r\n          }\r\n          const csv = exportAsCSV(key, rows);\r\n          downloadFile(csv, generateFilename(key, 'csv'), 'text/csv;charset=utf-8');\r\n        }\r\n        toast.success(`${csvKeys.length} fichier(s) CSV t├®l├®charg├®(s)`);\r\n      }\r\n      onClose();\r\n    } catch (err) {\r\n      console.error('[ExportModal] Erreur export:', err);\r\n      toast.error(\"L'export a ├®chou├®. Veuillez r├®essayer.\");\r\n    } finally {\r\n      setIsExporting(false);\r\n    }\r\n  };\r\n\r\n  // ÔöÇÔöÇÔöÇ Rendu ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\r\n\r\n  const csvOnlyCollections: CollectionKey[] = CSV_COLLECTION_KEYS;\r\n\r\n  return (\r\n    <>\r\n      {/* Backdrop */}\r\n      <div\r\n        className=\"fixed inset-0 z-50 bg-black/50 backdrop-blur-sm animate-fade-in\"\r\n        onClick={onClose}\r\n        aria-hidden=\"true\"\r\n      />\r\n\r\n      {/* Modal */}\r\n      <div\r\n        role=\"dialog\"\r\n        aria-modal=\"true\"\r\n        aria-labelledby=\"export-modal-title\"\r\n        className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\r\n      >\r\n        <div className=\"bg-white dark:bg-brand-900 rounded-3xl shadow-2xl w-full max-w-lg border border-brand-100 dark:border-brand-800 animate-slide-up\">\r\n          {/* Header */}\r\n          <div className=\"flex items-center justify-between p-6 border-b border-brand-100 dark:border-brand-800\">\r\n            <div className=\"flex items-center gap-3\">\r\n              <div className=\"p-2.5 bg-brand-100 dark:bg-brand-800 rounded-2xl\">\r\n                <Archive\r\n                  size={20}\r\n                  className=\"text-brand-600 dark:text-brand-300\"\r\n                  aria-hidden=\"true\"\r\n                />\r\n              </div>\r\n              <div>\r\n                <h2\r\n                  id=\"export-modal-title\"\r\n                  className=\"text-lg font-bold text-brand-900 dark:text-white\"\r\n                >\r\n                  Exporter vos donn├®es\r\n                </h2>\r\n                <p className=\"text-xs text-brand-500 dark:text-brand-400\">\r\n                  RGPD Art. 20 ÔÇö Portabilit├®\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <button\r\n              onClick={onClose}\r\n              title=\"Fermer\"\r\n              className=\"p-2 hover:bg-brand-100 dark:hover:bg-brand-800 rounded-xl transition-colors text-brand-500\"\r\n              aria-label=\"Fermer la modal d'export\"\r\n            >\r\n              <X size={18} />\r\n            </button>\r\n          </div>\r\n\r\n          <div className=\"p-6 space-y-6\">\r\n            {/* Choix du format */}\r\n            <fieldset>\r\n              <legend className=\"text-sm font-semibold text-brand-700 dark:text-brand-300 mb-3\">\r\n                Format d'export\r\n              </legend>\r\n              <div className=\"grid grid-cols-2 gap-3\">\r\n                <label\r\n                  className={`flex items-center gap-3 p-4 rounded-2xl border-2 transition-all cursor-pointer ${\r\n                    format === 'json'\r\n                      ? 'border-brand-500 bg-brand-50 dark:bg-brand-800/50 text-brand-700 dark:text-brand-200'\r\n                      : 'border-brand-100 dark:border-brand-800 hover:border-brand-300 text-brand-500'\r\n                  }`}\r\n                >\r\n                  <input\r\n                    type=\"radio\"\r\n                    name=\"export-format\"\r\n                    value=\"json\"\r\n                    checked={format === 'json'}\r\n                    onChange={() => setFormat('json')}\r\n                    className=\"sr-only\"\r\n                  />\r\n                  <FileJson size={24} aria-hidden=\"true\" />\r\n                  <div>\r\n                    <p className=\"font-bold text-sm\">JSON</p>\r\n                    <p className=\"text-[10px] opacity-70\">Backup complet</p>\r\n                  </div>\r\n                  {format === 'json' && (\r\n                    <Check size={14} className=\"ml-auto text-brand-500\" aria-hidden=\"true\" />\r\n                  )}\r\n                </label>\r\n\r\n                <label\r\n                  className={`flex items-center gap-3 p-4 rounded-2xl border-2 transition-all cursor-pointer ${\r\n                    format === 'csv'\r\n                      ? 'border-brand-500 bg-brand-50 dark:bg-brand-800/50 text-brand-700 dark:text-brand-200'\r\n                      : 'border-brand-100 dark:border-brand-800 hover:border-brand-300 text-brand-500'\r\n                  }`}\r\n                >\r\n                  <input\r\n                    type=\"radio\"\r\n                    name=\"export-format\"\r\n                    value=\"csv\"\r\n                    checked={format === 'csv'}\r\n                    onChange={() => setFormat('csv')}\r\n                    className=\"sr-only\"\r\n                  />\r\n                  <FileSpreadsheet size={24} aria-hidden=\"true\" />\r\n                  <div>\r\n                    <p className=\"font-bold text-sm\">CSV</p>\r\n                    <p className=\"text-[10px] opacity-70\">Compatible Excel</p>\r\n                  </div>\r\n                  {format === 'csv' && (\r\n                    <Check size={14} className=\"ml-auto text-brand-500\" aria-hidden=\"true\" />\r\n                  )}\r\n                </label>\r\n              </div>\r\n            </fieldset>\r\n\r\n            {/* Collections */}\r\n            <div>\r\n              <div className=\"flex items-center justify-between mb-3\">\r\n                <p className=\"text-sm font-semibold text-brand-700 dark:text-brand-300\">\r\n                  Collections ├á inclure\r\n                </p>\r\n                <div className=\"flex gap-2\">\r\n                  <button\r\n                    onClick={selectAll}\r\n                    className=\"text-[10px] font-bold uppercase tracking-wide text-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors\"\r\n                  >\r\n                    Tout\r\n                  </button>\r\n                  <span className=\"text-brand-200 dark:text-brand-700\">|</span>\r\n                  <button\r\n                    onClick={deselectAll}\r\n                    className=\"text-[10px] font-bold uppercase tracking-wide text-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors\"\r\n                  >\r\n                    Aucun\r\n                  </button>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"space-y-2 max-h-56 overflow-y-auto\">\r\n                {(Object.keys(COLLECTION_LABELS) as CollectionKey[]).map((key) => {\r\n                  const isDisabledForCSV = format === 'csv' && !csvOnlyCollections.includes(key);\r\n                  const count = (data[key] as unknown[]).length;\r\n                  const checked = selectedCollections.has(key) && !isDisabledForCSV;\r\n\r\n                  return (\r\n                    <label\r\n                      key={key}\r\n                      className={`flex items-center gap-3 p-3 rounded-xl cursor-pointer transition-colors ${\r\n                        isDisabledForCSV\r\n                          ? 'opacity-40 cursor-not-allowed'\r\n                          : 'hover:bg-brand-50 dark:hover:bg-brand-800/50'\r\n                      }`}\r\n                    >\r\n                      <input\r\n                        type=\"checkbox\"\r\n                        checked={checked}\r\n                        disabled={isDisabledForCSV}\r\n                        onChange={() => !isDisabledForCSV && toggleCollection(key)}\r\n                        className=\"w-4 h-4 rounded accent-brand-600\"\r\n                        aria-label={`Inclure ${COLLECTION_LABELS[key]}`}\r\n                      />\r\n                      <span className=\"flex-1 text-sm text-brand-700 dark:text-brand-300\">\r\n                        {COLLECTION_LABELS[key]}\r\n                      </span>\r\n                      <span className=\"text-xs font-mono text-brand-400 dark:text-brand-600 bg-brand-50 dark:bg-brand-800 px-2 py-0.5 rounded-full\">\r\n                        {count}\r\n                      </span>\r\n                    </label>\r\n                  );\r\n                })}\r\n              </div>\r\n\r\n              {format === 'csv' && (\r\n                <p className=\"mt-2 text-[10px] text-amber-600 dark:text-amber-400\">\r\n                  Le format CSV exporte chaque collection dans un fichier s├®par├®. Emails, mod├¿les et\r\n                  ├®v├®nements sont disponibles uniquement en JSON.\r\n                </p>\r\n              )}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Footer */}\r\n          <div className=\"flex items-center justify-end gap-3 p-6 border-t border-brand-100 dark:border-brand-800\">\r\n            <button\r\n              onClick={onClose}\r\n              className=\"px-5 py-2.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:bg-brand-50 dark:hover:bg-brand-800 rounded-xl transition-colors\"\r\n            >\r\n              Annuler\r\n            </button>\r\n            <button\r\n              onClick={handleExport}\r\n              disabled={isExporting || selectedCollections.size === 0}\r\n              className=\"flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-brand-600 hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed rounded-xl transition-colors\"\r\n              title=\"Lancer l'export\"\r\n            >\r\n              <Download size={16} aria-hidden=\"true\" />\r\n              {isExporting ? 'Export en cours...' : `Exporter (${selectedCollections.size})`}\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default ExportModal;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Thomas\\Micro-Gestion-Facile\\src\\components\\FormFieldValidated.tsx","messages":[{"ruleId":"complexity","severity":1,"message":"Arrow function has a complexity of 42. Maximum allowed is 15.","line":183,"column":4,"messageId":"complex","endLine":183,"endColumn":6}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Composant FormFieldValidated - FormField avec validation int├®gr├®e\r\n * Remplace le FormField basique avec validation live\r\n *\r\n * Usage simple:\r\n * ```tsx\r\n * <FormFieldValidated\r\n *   label=\"Email\"\r\n *   type=\"email\"\r\n *   value={email}\r\n *   onChange={setEmail}\r\n *   validator={validateEmail}\r\n * />\r\n *\r\n * <FormFieldValidated\r\n *   label=\"SIRET\"\r\n *   value={siret}\r\n *   onChange={setSiret}\r\n *   validator={validateSIRET}\r\n *   validationType=\"siret\"\r\n * />\r\n * ```\r\n */\r\n\r\nimport {\r\n  CircleAlert as AlertCircle,\r\n  CircleCheck as CheckCircle2,\r\n  type LucideIcon,\r\n} from \"lucide-react\";\r\nimport React, { useEffect, useState } from \"react\";\r\nimport {\r\n  validateAddressForm,\r\n  validateAmount,\r\n  validateDate,\r\n  validateEmailForm,\r\n  validateFrenchPostalCode,\r\n  validateIBAN,\r\n  validateName,\r\n  validatePhoneForm,\r\n  validateRequired,\r\n  validateSIREN,\r\n  validateSIRETForm,\r\n  validateTVANumberForm,\r\n  validateWebsiteForm,\r\n  type ValidationResult,\r\n} from \"../lib/zod-schemas\";\r\n\r\n// Aliases for validator map keys\r\nconst validateFrenchPhone = validatePhoneForm;\r\nconst validateVATNumber = validateTVANumberForm;\r\n\r\ntype ValidationType =\r\n  | \"siret\"\r\n  | \"siren\"\r\n  | \"iban\"\r\n  | \"email\"\r\n  | \"postal-code\"\r\n  | \"phone\"\r\n  | \"vat\"\r\n  | \"website\"\r\n  | \"name\"\r\n  | \"amount\"\r\n  | \"date\"\r\n  | \"required\"\r\n  | \"address\"\r\n  | \"none\";\r\n\r\n// Map des validateurs - accepte any pour les diff├®rentes signatures de validateurs\r\nconst validatorsMap: Record<\r\n  ValidationType,\r\n  (value: unknown) => ValidationResult\r\n> = {\r\n  siret: validateSIRETForm,\r\n  siren: validateSIREN,\r\n  iban: validateIBAN,\r\n  email: validateEmailForm,\r\n  \"postal-code\": validateFrenchPostalCode,\r\n  phone: validateFrenchPhone,\r\n  vat: validateVATNumber,\r\n  website: validateWebsiteForm,\r\n  name: validateName,\r\n  amount: validateAmount,\r\n  date: validateDate,\r\n  required: validateRequired,\r\n  address: validateAddressForm,\r\n  none: () => ({ valid: true }),\r\n};\r\n\r\n// Suggestions d'auto-d├®tection sur type HTML\r\nconst htmlTypeToValidation: Record<string, ValidationType> = {\r\n  email: \"email\",\r\n  tel: \"phone\",\r\n  date: \"date\",\r\n  url: \"website\",\r\n  number: \"amount\",\r\n  text: \"none\",\r\n};\r\n\r\nconst getFieldBorderClass = (hasErr: boolean, hasSuc: boolean): string => {\r\n  if (hasErr) {\r\n    return \"border-red-500 focus:ring-red-500/10 focus:border-red-600\";\r\n  }\r\n  if (hasSuc) {\r\n    return \"border-green-500 focus:ring-green-500/10 focus:border-green-600\";\r\n  }\r\n  return \"\";\r\n};\r\n\r\ninterface FormFieldValidatedProps {\r\n  id?: string;\r\n  label: string;\r\n  description?: string;\r\n  required?: boolean;\r\n  /**\r\n   * Type HTML standard ou custom pour auto-d├®tection\r\n   */\r\n  type?:\r\n    | \"text\"\r\n    | \"email\"\r\n    | \"number\"\r\n    | \"password\"\r\n    | \"url\"\r\n    | \"tel\"\r\n    | \"search\"\r\n    | \"date\"\r\n    | \"checkbox\"\r\n    | \"textarea\";\r\n  value: string | number;\r\n  onChange: (value: string) => void;\r\n  /**\r\n   * Validator personnalis├® (surcharge auto-d├®tection)\r\n   */\r\n  validator?: (value: string | number) => ValidationResult;\r\n  /**\r\n   * Type de validation: si fourni, surcharge auto-d├®tection et validator prop\r\n   */\r\n  validationType?: ValidationType;\r\n  placeholder?: string;\r\n  icon?: LucideIcon;\r\n  className?: string;\r\n  inputClassName?: string;\r\n  min?: string | number;\r\n  max?: string | number;\r\n  step?: string | number;\r\n  validateOnChange?: boolean;\r\n  validateOnBlur?: boolean;\r\n  showErrorsImmediate?: boolean;\r\n  showValidationIcon?: boolean;\r\n  \"aria-label\"?: string;\r\n  autoComplete?: string;\r\n  maxLength?: number;\r\n  error?: ValidationResult | null;\r\n  touched?: boolean;\r\n}\r\n\r\nexport const FormFieldValidated: React.FC<FormFieldValidatedProps> = ({\r\n  id,\r\n  label,\r\n  description,\r\n  required = false,\r\n  type = \"text\",\r\n  value,\r\n  onChange,\r\n  validator,\r\n  validationType,\r\n  placeholder,\r\n  icon: Icon,\r\n  className = \"\",\r\n  inputClassName = \"\",\r\n  min,\r\n  max,\r\n  step,\r\n  validateOnChange = true,\r\n  validateOnBlur = true,\r\n  showErrorsImmediate = true,\r\n  showValidationIcon = true,\r\n  \"aria-label\": ariaLabel,\r\n  maxLength,\r\n  autoComplete: _autoComplete,\r\n  // Propri├®t├®s optionnelles pour int├®gration avec useFormValidation\r\n  error: externalError,\r\n  touched: externalTouched,\r\n}) => {\r\n  const isTextarea = type === \"textarea\";\r\n\r\n  // D├®terminer le validateur ├á utiliser\r\n  const determineValidator = (): ((\r\n    value: string | number,\r\n  ) => ValidationResult) => {\r\n    // Si validationType est fourni, utiliser ├ºa\r\n    if (validationType) {\r\n      return validatorsMap[validationType];\r\n    }\r\n\r\n    // Si validator personnalis├® est fourni\r\n    if (validator) {\r\n      return validator;\r\n    }\r\n\r\n    // Auto-d├®tection bas├®e sur type HTML\r\n    const autoDetectedValidation = htmlTypeToValidation[type] || \"none\";\r\n    return validatorsMap[autoDetectedValidation];\r\n  };\r\n\r\n  const finalValidator = determineValidator();\r\n\r\n  // ├ëtat de validation interne (fallback si pas d'error externe)\r\n  const [internalError, setInternalError] = useState<ValidationResult | null>(\r\n    null,\r\n  );\r\n  const [internalTouched, setInternalTouched] = useState(false);\r\n\r\n  // Validation au changement\r\n  useEffect(() => {\r\n    if (validateOnChange && value !== undefined) {\r\n      const result = finalValidator(value);\r\n      setInternalError(result);\r\n    }\r\n  }, [value, finalValidator, validateOnChange]);\r\n\r\n  // D├®terminer l'erreur et le statut touch├® final\r\n  const currentError =\r\n    externalError !== undefined ? externalError : internalError;\r\n  const isTouched =\r\n    externalTouched ?? internalTouched;\r\n\r\n  // Afficher l'erreur si on a une erreur ET (soit on affiche tout de suite, soit le champ a ├®t├® touch├®)\r\n  const shouldShowError =\r\n    currentError && !currentError.valid && (showErrorsImmediate || isTouched);\r\n  const isValid = currentError?.valid === true;\r\n\r\n  // Handler combin├® pour onChange\r\n  const handleChange = (\r\n    e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>,\r\n  ) => {\r\n    const newValue = e.target.value;\r\n    onChange(newValue);\r\n  };\r\n\r\n  const handleBlur = (\r\n    e: React.FocusEvent<HTMLInputElement | HTMLTextAreaElement>,\r\n  ) => {\r\n    setInternalTouched(true);\r\n    if (validateOnBlur) {\r\n      const result = finalValidator(e.target.value);\r\n      setInternalError(result);\r\n    }\r\n  };\r\n\r\n  const fieldId = id ?? `field-${label.toLowerCase().replaceAll(/\\s+/g, \"-\")}`;\r\n\r\n  let describedByValue: string | undefined;\r\n  if (shouldShowError) {\r\n    describedByValue = `${fieldId}-error`;\r\n  } else if (description) {\r\n    describedByValue = `${fieldId}-description`;\r\n  }\r\n\r\n  const ariaAttrs = {\r\n    \"aria-required\": required ? (\"true\" as const) : (\"false\" as const),\r\n    \"aria-invalid\":\r\n      !isValid && isTouched ? (\"true\" as const) : (\"false\" as const),\r\n  };\r\n\r\n  const hasError = shouldShowError;\r\n  const hasSuccess = currentError && currentError.valid && value;\r\n\r\n  return (\r\n    <div className={`space-y-1.5 ${className}`}>\r\n      {/* Label */}\r\n      <div className=\"flex items-center justify-between gap-2\">\r\n        <label\r\n          htmlFor={fieldId}\r\n          className=\"block text-[10px] font-bold text-brand-400 dark:text-brand-500 uppercase tracking-widest\"\r\n        >\r\n          {label}\r\n          {required && (\r\n            <span className=\"text-red-500 ml-1\" aria-hidden=\"true\">\r\n              *\r\n            </span>\r\n          )}\r\n        </label>\r\n        {showValidationIcon && hasSuccess && (\r\n          <CheckCircle2\r\n            size={14}\r\n            className=\"text-green-600 dark:text-green-400\"\r\n            aria-hidden=\"true\"\r\n          />\r\n        )}\r\n      </div>\r\n\r\n      {/* Input Container */}\r\n      <div className=\"relative\">\r\n        {Icon && (\r\n          <Icon\r\n            className=\"absolute left-4 top-1/2 -translate-y-1/2 text-brand-300 dark:text-brand-600 pointer-events-none\"\r\n            size={18}\r\n            aria-hidden=\"true\"\r\n          />\r\n        )}\r\n\r\n        {isTextarea ? (\r\n          <textarea\r\n            id={fieldId}\r\n            required={required}\r\n            value={value}\r\n            onChange={handleChange}\r\n            onBlur={handleBlur}\r\n            placeholder={placeholder}\r\n            {...(_autoComplete && { autoComplete: _autoComplete })}\r\n            {...ariaAttrs}\r\n            aria-label={ariaLabel}\r\n            aria-describedby={describedByValue}\r\n            maxLength={maxLength}\r\n            className={`w-full ${Icon ? \"pl-12\" : \"pl-4\"} p-4 bg-white dark:bg-(--input-bg) border border-(--input-border) rounded-2xl outline-none focus:ring-4 focus:ring-(--input-focus-ring) focus:border-(--input-focus-border) text-(--input-text) placeholder:text-(--input-placeholder) transition-all resize-y min-h-24 ${getFieldBorderClass(!!hasError, !!(currentError && currentError.valid && value))} ${inputClassName}`}\r\n          />\r\n        ) : (\r\n          <input\r\n            id={fieldId}\r\n            type={type}\r\n            required={required}\r\n            value={value}\r\n            onChange={handleChange}\r\n            onBlur={handleBlur}\r\n            placeholder={placeholder}\r\n            {...(_autoComplete && { autoComplete: _autoComplete })}\r\n            {...ariaAttrs}\r\n            aria-label={ariaLabel}\r\n            aria-describedby={describedByValue}\r\n            min={min}\r\n            max={max}\r\n            step={step}\r\n            maxLength={maxLength}\r\n            className={`w-full ${Icon ? \"pl-12\" : \"pl-4\"} p-4 bg-white dark:bg-(--input-bg) border border-(--input-border) rounded-2xl outline-none focus:ring-4 focus:ring-(--input-focus-ring) focus:border-(--input-focus-border) text-(--input-text) placeholder:text-(--input-placeholder) transition-all ${getFieldBorderClass(!!hasError, !!(currentError && currentError.valid && value))} ${inputClassName}`}\r\n          />\r\n        )}\r\n\r\n        {/* Erreur Icon */}\r\n        {showValidationIcon && hasError && (\r\n          <AlertCircle\r\n            size={18}\r\n            className=\"absolute right-4 top-1/2 -translate-y-1/2 text-red-600 dark:text-red-400 pointer-events-none\"\r\n            aria-hidden=\"true\"\r\n          />\r\n        )}\r\n      </div>\r\n\r\n      {/* Description */}\r\n      {description && (\r\n        <p\r\n          id={`${fieldId}-description`}\r\n          className=\"text-[10px] text-brand-400 dark:text-brand-500 mt-1 font-medium italic\"\r\n        >\r\n          {description}\r\n        </p>\r\n      )}\r\n\r\n      {/* Erreur */}\r\n      {hasError && (\r\n        <p\r\n          id={`${fieldId}-error`}\r\n          className=\"text-[10px] text-red-600 dark:text-red-400 font-medium flex items-center gap-1\"\r\n        >\r\n          <AlertCircle size={12} aria-hidden=\"true\" />\r\n          {currentError.error}\r\n        </p>\r\n      )}\r\n\r\n      {/* Succ├¿s (optionnel) */}\r\n      {hasSuccess && !description && (\r\n        <p className=\"text-[10px] text-green-600 dark:text-green-400 font-medium flex items-center gap-1\">\r\n          <CheckCircle2 size={12} aria-hidden=\"true\" />\r\n          Valide !\r\n        </p>\r\n      )}\r\n    </div>\r\n  );\r\n};\r\n\r\n/**\r\n * Preset pour champs courants (avec le bon type de validation pr├®-configur├®)\r\n */\r\n\r\nexport const SIRETField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    validationType=\"siret\"\r\n    placeholder=\"12345678901234\"\r\n    maxLength={14}\r\n  />\r\n);\r\n\r\nexport const SIRENField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    validationType=\"siren\"\r\n    placeholder=\"123456789\"\r\n    maxLength={9}\r\n  />\r\n);\r\n\r\nexport const IBANField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    validationType=\"iban\"\r\n    placeholder=\"FR1420041010050500013M02800\"\r\n    maxLength={34}\r\n    autoComplete=\"off\"\r\n  />\r\n);\r\n\r\nexport const EmailField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\" | \"type\">\r\n> = (props) => (\r\n  <FormFieldValidated {...props} type=\"email\" validationType=\"email\" />\r\n);\r\n\r\nexport const PhoneField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\" | \"type\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    type=\"tel\"\r\n    validationType=\"phone\"\r\n    placeholder=\"0123456789\"\r\n  />\r\n);\r\n\r\nexport const PostalCodeField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    validationType=\"postal-code\"\r\n    placeholder=\"75001\"\r\n    maxLength={5}\r\n  />\r\n);\r\n\r\nexport const VATField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    validationType=\"vat\"\r\n    placeholder=\"FR12345678901\"\r\n    maxLength={15}\r\n  />\r\n);\r\n\r\nexport const WebsiteField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\" | \"type\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    type=\"url\"\r\n    validationType=\"website\"\r\n    placeholder=\"https://example.com\"\r\n    autoComplete=\"url\"\r\n  />\r\n);\r\n\r\nexport const AmountField: React.FC<\r\n  Omit<FormFieldValidatedProps, \"validationType\" | \"type\">\r\n> = (props) => (\r\n  <FormFieldValidated\r\n    {...props}\r\n    type=\"number\"\r\n    validationType=\"amount\"\r\n    step={0.01}\r\n    min=\"0\"\r\n    autoComplete=\"off\"\r\n  />\r\n);\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Thomas\\Micro-Gestion-Facile\\src\\components\\FormFields.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Thomas\\Micro-Gestion-Facile\\src\\components\\GitHubLoginButton.tsx","messages":[{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise returned in function argument where a void return was expected.","line":83,"column":11,"messageId":"voidReturnArgument","endLine":83,"endColumn":22},{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":104,"column":17,"messageId":"voidReturnAttribute","endLine":104,"endColumn":30}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * Bouton de Connexion GitHub - Composant R├®utilisable\r\n * Ô£à Accessibilit├® (a11y) compl├¿te\r\n * Ô£à Gestion d'erreurs avec feedback utilisateur\r\n * Ô£à Support offline avec retry\r\n * Ô£à Animations et loading states\r\n */\r\n\r\nimport { LoaderCircle as Loader2 } from \"lucide-react\";\r\nimport { useEffect, useRef, useState } from \"react\";\r\nimport { useGitHubAuth } from \"../hooks/useGitHubAuth\";\r\n\r\nexport interface GitHubLoginButtonProps {\r\n  readonly onSuccess?: (username: string) => void;\r\n  readonly onError?: (error: Error) => void;\r\n  readonly label?: string;\r\n  readonly className?: string;\r\n  readonly showText?: boolean;\r\n  readonly rememberMe?: boolean;\r\n  readonly disabled?: boolean;\r\n}\r\n\r\n/**\r\n * Button Connexion GitHub am├®lior├® avec Tailwind CSS\r\n */\r\nexport function GitHubLoginButton({\r\n  onSuccess,\r\n  onError,\r\n  label = \"Se connecter avec GitHub\",\r\n  className = \"\",\r\n  showText = true,\r\n  rememberMe = true,\r\n  disabled = false,\r\n}: GitHubLoginButtonProps) {\r\n  const { loginWithGitHub, isLoading, error, user } = useGitHubAuth();\r\n  const [localError, setLocalError] = useState<string | null>(null);\r\n  const [retryCount, setRetryCount] = useState(0);\r\n  const retryTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);\r\n\r\n  // D├®terminer l'├®tat disabled global (parent + local)\r\n  const isDisabled = disabled || isLoading;\r\n\r\n  // R├®initialiser les erreurs quand l'utilisateur est connect├®\r\n  useEffect(() => {\r\n    if (user) {\r\n      setLocalError(null);\r\n      onSuccess?.((user.displayName ?? user.email) ?? \"Utilisateur\");\r\n    }\r\n  }, [user, onSuccess]);\r\n\r\n  // Notifier les erreurs\r\n  useEffect(() => {\r\n    if (error) {\r\n      setLocalError(error.message);\r\n      onError?.(error);\r\n    }\r\n  }, [error, onError]);\r\n\r\n  // Annuler le retry si le composant est d├®mont├®\r\n  useEffect(() => {\r\n    return () => {\r\n      if (retryTimeoutRef.current !== null) {\r\n        clearTimeout(retryTimeoutRef.current);\r\n      }\r\n    };\r\n  }, []);\r\n\r\n  const handleClick = async () => {\r\n    try {\r\n      setLocalError(null);\r\n      await loginWithGitHub(rememberMe);\r\n\r\n      // R├®initialiser le compteur de retry en cas de succ├¿s\r\n      setRetryCount(0);\r\n    } catch (err) {\r\n      const error = err instanceof Error ? err : new Error(\"Erreur connexion\");\r\n\r\n      // Retry automatique pour les erreurs r├®seau (max 3 tentatives)\r\n      if (error.message.includes(\"r├®seau\") && retryCount < 3) {\r\n        setRetryCount((prev) => prev + 1);\r\n        // Backoff exponentiel avec r├®f├®rence stock├®e pour annulation au d├®montage\r\n        retryTimeoutRef.current = setTimeout(\r\n          handleClick,\r\n          Math.pow(2, retryCount) * 1000,\r\n        );\r\n      } else {\r\n        setLocalError(error.message);\r\n        onError?.(error);\r\n      }\r\n    }\r\n  };\r\n\r\n  // D├®terminer le texte ├á afficher\r\n  let displayText = label;\r\n  if (isLoading) {\r\n    displayText = \"Connexion en cours...\";\r\n  } else if (retryCount > 0) {\r\n    displayText = `Reconnexion (tentative ${retryCount}/3)...`;\r\n  }\r\n\r\n  return (\r\n    <div className={`w-full flex flex-col gap-4 ${className}`}>\r\n      <button\r\n        onClick={handleClick}\r\n        disabled={isDisabled}\r\n        aria-label={showText ? displayText : \"Se connecter avec GitHub\"}\r\n        title={showText ? \"\" : label}\r\n        className={`\r\n          w-full flex items-center justify-center gap-3 px-4 py-3 sm:py-4\r\n          rounded-2xl font-bold\r\n          transition-all duration-200\r\n          shadow-lg\r\n          hover:scale-100 sm:hover:scale-[1.02]\r\n          active:scale-95\r\n          disabled:opacity-60\r\n          disabled:cursor-not-allowed\r\n          disabled:scale-100\r\n          group\r\n          ${\r\n            className.includes(\"bg-\")\r\n              ? \"\"\r\n              : \"bg-white dark:bg-brand-900/50 text-gray-900 dark:text-white border-2 border-brand-200 dark:border-brand-800 hover:border-brand-300 dark:hover:border-brand-700\"\r\n          }\r\n        `}\r\n      >\r\n        <div className=\"flex items-center gap-3 h-6\">\r\n          {isLoading ? (\r\n            <Loader2 size={20} className=\"animate-spin\" />\r\n          ) : (\r\n            <svg\r\n              aria-hidden=\"true\"\r\n              width=\"20\"\r\n              height=\"20\"\r\n              viewBox=\"0 0 16 16\"\r\n              fill=\"currentColor\"\r\n            >\r\n              <path d=\"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z\" />\r\n            </svg>\r\n          )}\r\n          {showText && <span>{displayText}</span>}\r\n        </div>\r\n      </button>\r\n\r\n      {localError && (\r\n        <div\r\n          className=\"flex items-start gap-3 p-4 bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 rounded-lg animate-in fade-in slide-in-from-top-4 duration-300\"\r\n          role=\"alert\"\r\n          aria-live=\"polite\"\r\n        >\r\n          <span className=\"shrink-0 text-lg\">ÔÜá´©Å</span>\r\n          <div className=\"flex-1\">\r\n            <p className=\"font-bold text-red-800 dark:text-red-200 text-sm\">\r\n              Erreur de connexion\r\n            </p>\r\n            <p className=\"text-red-700 dark:text-red-300 text-xs mt-1\">\r\n              {localError}\r\n            </p>\r\n          </div>\r\n          <button\r\n            onClick={() => setLocalError(null)}\r\n            className=\"text-red-400 hover:text-red-600 dark:hover:text-red-200 transition-colors\"\r\n          >\r\n            ├ù\r\n          </button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Thomas\\Micro-Gestion-Facile\\src\\components\\InvoiceManager.tsx","messages":[{"ruleId":"@typescript-eslint/no-floating-promises","severity":1,"message":"Promises must be awaited, end with a call to .catch, end with a call to .then with a rejection handler or be explicitly marked as ignored with the `void` operator.","line":168,"column":9,"messageId":"floatingVoid","endLine":168,"endColumn":30,"suggestions":[{"messageId":"floatingFixVoid","fix":{"range":[4653,4653],"text":"void "},"desc":"Add void operator to ignore."},{"messageId":"floatingFixAwait","fix":{"range":[4653,4653],"text":"await "},"desc":"Add await operator."}]},{"ruleId":"@typescript-eslint/no-floating-promises","severity":1,"message":"Promises must be awaited, end with a call to .catch, end with a call to .then with a rejection handler or be explicitly marked as ignored with the `void` operator.","line":201,"column":9,"messageId":"floatingVoid","endLine":201,"endColumn":30,"suggestions":[{"messageId":"floatingFixVoid","fix":{"range":[5619,5619],"text":"void "},"desc":"Add void operator to ignore."},{"messageId":"floatingFixAwait","fix":{"range":[5619,5619],"text":"await "},"desc":"Add await operator."}]},{"ruleId":"@typescript-eslint/no-floating-promises","severity":1,"message":"Promises must be awaited, end with a call to .catch, end with a call to .then with a rejection handler or be explicitly marked as ignored with the `void` operator.","line":206,"column":9,"messageId":"floatingVoid","endLine":206,"endColumn":28,"suggestions":[{"messageId":"floatingFixVoid","fix":{"range":[5807,5807],"text":"void "},"desc":"Add void operator to ignore."},{"messageId":"floatingFixAwait","fix":{"range":[5807,5807],"text":"await "},"desc":"Add await operator."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useCallback has a missing dependency: 'playSound'. Either include it or remove the dependency array.","line":212,"column":5,"endLine":212,"endColumn":18,"suggestions":[{"desc":"Update the dependencies array to be: [playSound, userProfile]","fix":{"range":[5960,5973],"text":"[playSound, userProfile]"}}]},{"ruleId":"no-nested-ternary","severity":1,"message":"Do not nest ternary expressions.","line":389,"column":10,"messageId":"noNestedTernary","endLine":624,"endColumn":10},{"ruleId":"complexity","severity":1,"message":"Arrow function has a complexity of 24. Maximum allowed is 15.","line":432,"column":35,"messageId":"complex","endLine":432,"endColumn":37},{"ruleId":"no-nested-ternary","severity":1,"message":"Do not nest ternary expressions.","line":534,"column":29,"messageId":"noNestedTernary","endLine":538,"endColumn":98},{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":557,"column":39,"messageId":"voidReturnAttribute","endLine":557,"endColumn":73},{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":574,"column":35,"messageId":"voidReturnAttribute","endLine":574,"endColumn":58},{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":583,"column":35,"messageId":"voidReturnAttribute","endLine":583,"endColumn":64},{"ruleId":"@typescript-eslint/no-misused-promises","severity":1,"message":"Promise-returning function provided to attribute where a void return was expected.","line":591,"column":35,"messageId":"voidReturnAttribute","endLine":591,"endColumn":59}],"suppressedMessages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'products' is defined but never used. Allowed unused args must match /^_/u.","line":50,"column":3,"messageId":"unusedVar","endLine":50,"endColumn":11,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":11,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import {\r\n  ArrowRightLeft,\r\n  Calendar,\r\n  Copy,\r\n  Lock,\r\n  Mail,\r\n  MailWarning,\r\n  Plus,\r\n  Printer,\r\n  ShieldCheck,\r\n  Trash2,\r\n  TrendingUp,\r\n} from \"lucide-react\";\r\nimport React, { Suspense, useCallback, useMemo, useState } from \"react\";\r\nimport { toast } from \"sonner\";\r\nimport { useInvoiceActions } from \"../hooks/useInvoiceActions\";\r\nimport useNotificationsSound from \"../hooks/useNotificationsSound\";\r\nimport { signInvoice } from \"../lib/electronicSignature\";\r\nimport { useAppStore } from \"../store/appStore\";\r\nimport type {\r\n  Client,\r\n  DocumentType,\r\n  Invoice,\r\n  Product,\r\n  UserProfile,\r\n} from \"../types\";\r\nimport { InvoiceStatus } from \"../types/invoice\";\r\nimport { TableRowSkeleton } from \"./Skeleton\";\r\n\r\nconst InvoicePaper = React.lazy(() => import(\"./InvoicePaper\"));\r\n\r\ntype FilterStatus = \"all\" | InvoiceStatus | string;\r\n\r\ninterface InvoiceManagerProps {\r\n  invoices: Invoice[];\r\n  setInvoices: (invoices: Invoice[]) => void;\r\n  clients: Client[];\r\n  userProfile: UserProfile;\r\n  products: Product[];\r\n  onSave?: (invoice: Invoice) => void;\r\n  onDelete?: (id: string) => void;\r\n}\r\n\r\nconst InvoiceManager: React.FC<InvoiceManagerProps> = ({\r\n  invoices,\r\n  setInvoices,\r\n  clients,\r\n  userProfile,\r\n  // eslint-disable-next-line @typescript-eslint/no-unused-vars\r\n  products,\r\n  onSave,\r\n  onDelete,\r\n}) => {\r\n  const [filterStatus, setFilterStatus] = useState<FilterStatus>(\"all\");\r\n  const [filterType, setFilterType] = useState<DocumentType | \"all\">(\"all\");\r\n  const [sortBy, setSortBy] = useState<\"date\" | \"number\" | \"total\">(\"date\");\r\n  const [searchTerm, setSearchTerm] = useState(\"\");\r\n  const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set());\r\n  const [previewInvoice, setPreviewInvoice] = useState<Invoice | null>(null);\r\n  const [signingId, setSigningId] = useState<string | null>(null);\r\n\r\n  const { playSound } = useNotificationsSound();\r\n  const isSyncing = useAppStore((state) => state.isSyncing);\r\n\r\n  // ÔöÇÔöÇÔöÇ ACTIONS ÔöÇÔöÇÔöÇ\r\n  const {\r\n    getDocumentLabel,\r\n    duplicateInvoice,\r\n    sendByEmail,\r\n    deleteInvoice,\r\n    updateInvoiceStatus,\r\n    exportToCSV,\r\n    convertQuoteToInvoice,\r\n    sendReminderByEmail,\r\n  } = useInvoiceActions({\r\n    invoices,\r\n    setInvoices,\r\n    clients,\r\n    userProfile,\r\n    onSave,\r\n    onDelete,\r\n  });\r\n\r\n  // ÔöÇÔöÇÔöÇ STATISTIQUES ÔöÇÔöÇÔöÇ\r\n  const stats = useMemo(() => {\r\n    const now = new Date();\r\n    return invoices.reduce(\r\n      (acc, inv) => {\r\n        if (inv.type === \"invoice\") {\r\n          acc.totalInvoiced += inv.total;\r\n          if (\r\n            inv.status !== InvoiceStatus.PAID &&\r\n            inv.status !== InvoiceStatus.CANCELLED\r\n          ) {\r\n            acc.pendingPayment += inv.total;\r\n            if (inv.dueDate && new Date(inv.dueDate) < now) {\r\n              acc.overdueCount += 1;\r\n            }\r\n          }\r\n        } else if (inv.type === \"quote\" && inv.status === InvoiceStatus.DRAFT) {\r\n          acc.quotesToFollowUp += 1;\r\n        }\r\n        return acc;\r\n      },\r\n      {\r\n        totalInvoiced: 0,\r\n        pendingPayment: 0,\r\n        overdueCount: 0,\r\n        quotesToFollowUp: 0,\r\n      },\r\n    );\r\n  }, [invoices]);\r\n\r\n  // ÔöÇÔöÇÔöÇ FILTRAGE & TRI ÔöÇÔöÇÔöÇ\r\n  const filtered = useMemo(() => {\r\n    const result = invoices.filter((inv) => {\r\n      if (filterStatus !== \"all\" && inv.status !== filterStatus) {\r\n        return false;\r\n      }\r\n      if (filterType !== \"all\" && inv.type !== filterType) {\r\n        return false;\r\n      }\r\n\r\n      if (searchTerm) {\r\n        const client = clients.find((c) => c.id === inv.clientId);\r\n        const searchLower = searchTerm.toLowerCase();\r\n        if (\r\n          !inv.number.toLowerCase().includes(searchLower) &&\r\n          !client?.name.toLowerCase().includes(searchLower)\r\n        ) {\r\n          return false;\r\n        }\r\n      }\r\n\r\n      return true;\r\n    });\r\n\r\n    result.sort((a, b) => {\r\n      if (sortBy === \"date\") {\r\n        return new Date(b.date).getTime() - new Date(a.date).getTime();\r\n      }\r\n      if (sortBy === \"number\") {\r\n        return b.number.localeCompare(a.number);\r\n      }\r\n      if (sortBy === \"total\") {\r\n        return b.total - a.total;\r\n      }\r\n      return 0;\r\n    });\r\n\r\n    return result;\r\n  }, [invoices, filterStatus, filterType, searchTerm, clients, sortBy]);\r\n\r\n  // ÔöÇÔöÇÔöÇ HANDLERS ÔöÇÔöÇÔöÇ\r\n  const handleDelete = useCallback(\r\n    (id: string) => {\r\n      if (confirm(\"Supprimer ce document?\")) {\r\n        deleteInvoice(id);\r\n      }\r\n    },\r\n    [deleteInvoice],\r\n  );\r\n\r\n  const handleStatusChange = useCallback(\r\n    (id: string, status: string) => {\r\n      updateInvoiceStatus(id, status);\r\n      if (status === InvoiceStatus.PAID) {\r\n        playSound(\"success\");\r\n      }\r\n    },\r\n    [updateInvoiceStatus, playSound],\r\n  );\r\n\r\n  const handleBulkExport = useCallback(() => {\r\n    if (selectedIds.size === 0) {\r\n      alert(\"S├®lectionnez au moins un document\");\r\n      return;\r\n    }\r\n\r\n    const selectedDocs = invoices.filter((i) => selectedIds.has(i.id));\r\n    exportToCSV(selectedDocs, selectedDocs[0]?.type || \"invoice\");\r\n  }, [selectedIds, invoices, exportToCSV]);\r\n\r\n  const handleBulkDelete = useCallback(() => {\r\n    if (selectedIds.size === 0) {\r\n      alert(\"S├®lectionnez au moins un document\");\r\n      return;\r\n    }\r\n\r\n    if (confirm(`Supprimer ${selectedIds.size} document(s)?`)) {\r\n      selectedIds.forEach((id) => deleteInvoice(id));\r\n      setSelectedIds(new Set());\r\n    }\r\n  }, [selectedIds, deleteInvoice]);\r\n\r\n  const handleSign = useCallback(\r\n    async (inv: Invoice) => {\r\n      setSigningId(inv.id);\r\n      try {\r\n        const sig = await signInvoice(inv, userProfile);\r\n        playSound(\"success\");\r\n        toast.success(`Facture ${inv.number} sign├®e`, {\r\n          description: `Empreinte : ${sig.signature.slice(0, 16)}ÔÇª`,\r\n        });\r\n      } catch {\r\n        playSound(\"error\");\r\n        toast.error(\"Erreur lors de la signature num├®rique\");\r\n      } finally {\r\n        setSigningId(null);\r\n      }\r\n    },\r\n    [userProfile],\r\n  );\r\n\r\n  return (\r\n    <div className=\"space-y-6 max-w-7xl mx-auto pb-12\">\r\n      {/* HEADER */}\r\n      <div className=\"flex justify-between items-center\">\r\n        <h2 className=\"text-3xl font-black text-brand-900 dark:text-white\">\r\n          Documents\r\n        </h2>\r\n        <button className=\"bg-brand-900 text-white px-6 py-3 rounded-2xl flex items-center gap-2 hover:bg-brand-800\">\r\n          <Plus size={20} />\r\n          Nouveau\r\n        </button>\r\n      </div>\r\n\r\n      {/* STATS WIDGETS */}\r\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n        <div className=\"bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className=\"p-3 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-xl\">\r\n              <TrendingUp size={24} />\r\n            </div>\r\n            <div>\r\n              <p className=\"text-sm text-gray-500 dark:text-gray-400\">\r\n                Total Factur├® HT\r\n              </p>\r\n              <p className=\"text-xl font-bold dark:text-white\">\r\n                {stats.totalInvoiced.toLocaleString(\"fr-FR\", {\r\n                  minimumFractionDigits: 2,\r\n                })}{\" \"}\r\n                Ôé¼\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className=\"p-3 bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-xl\">\r\n              <Calendar size={24} />\r\n            </div>\r\n            <div>\r\n              <p className=\"text-sm text-gray-500 dark:text-gray-400\">\r\n                En attente paiement\r\n              </p>\r\n              <p className=\"text-xl font-bold dark:text-white\">\r\n                {stats.pendingPayment.toLocaleString(\"fr-FR\", {\r\n                  minimumFractionDigits: 2,\r\n                })}{\" \"}\r\n                Ôé¼\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className=\"p-3 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-xl\">\r\n              <ShieldCheck size={24} />\r\n            </div>\r\n            <div>\r\n              <p className=\"text-sm text-gray-500 dark:text-gray-400\">\r\n                Factures en retard\r\n              </p>\r\n              <p className=\"text-xl font-bold dark:text-white\">\r\n                {stats.overdueCount}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700\">\r\n          <div className=\"flex items-center gap-4\">\r\n            <div className=\"p-3 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-xl\">\r\n              <Mail size={24} />\r\n            </div>\r\n            <div>\r\n              <p className=\"text-sm text-gray-500 dark:text-gray-400\">\r\n                Devis ├á relancer\r\n              </p>\r\n              <p className=\"text-xl font-bold dark:text-white\">\r\n                {stats.quotesToFollowUp}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* FILTERS */}\r\n      <div className=\"bg-white dark:bg-gray-800 p-4 rounded-lg space-y-4\">\r\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\r\n          {/* Search */}\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Rechercher... (num├®ro ou client)\"\r\n            value={searchTerm}\r\n            onChange={(e: React.ChangeEvent<HTMLInputElement>) =>\r\n              setSearchTerm(e.target.value)\r\n            }\r\n            className=\"px-3 py-2 border rounded dark:bg-gray-700 dark:text-white\"\r\n          />\r\n\r\n          {/* Filter by Type */}\r\n          <select\r\n            value={filterType}\r\n            onChange={(e: React.ChangeEvent<HTMLSelectElement>) =>\r\n              setFilterType(e.target.value as DocumentType | \"all\")\r\n            }\r\n            className=\"px-3 py-2 border rounded dark:bg-gray-700 dark:text-white\"\r\n            title=\"Filtrer par type de document\"\r\n          >\r\n            <option value=\"all\">Tous types</option>\r\n            <option value=\"invoice\">Factures</option>\r\n            <option value=\"quote\">Devis</option>\r\n            <option value=\"order\">Commandes</option>\r\n            <option value=\"credit_note\">Avoirs</option>\r\n          </select>\r\n\r\n          {/* Filter by Status */}\r\n          <select\r\n            value={filterStatus}\r\n            onChange={(e: React.ChangeEvent<HTMLSelectElement>) =>\r\n              setFilterStatus(e.target.value as FilterStatus)\r\n            }\r\n            className=\"px-3 py-2 border rounded dark:bg-gray-700 dark:text-white\"\r\n            title=\"Filtrer par statut\"\r\n          >\r\n            <option value=\"all\">Tous statuts</option>\r\n            <option value=\"Brouillon\">Brouillon</option>\r\n            <option value=\"Envoy├®e\">Envoy├®e</option>\r\n            <option value=\"Pay├®e\">Pay├®e</option>\r\n            <option value=\"Annul├®e\">Annul├®e</option>\r\n          </select>\r\n\r\n          {/* Sort By */}\r\n          <select\r\n            value={sortBy}\r\n            onChange={(e: React.ChangeEvent<HTMLSelectElement>) =>\r\n              setSortBy(e.target.value as \"date\" | \"number\" | \"total\")\r\n            }\r\n            className=\"px-3 py-2 border rounded dark:bg-gray-700 dark:text-white\"\r\n            title=\"Trier par\"\r\n          >\r\n            <option value=\"date\">Date Ôåô</option>\r\n            <option value=\"number\">Num├®ro</option>\r\n            <option value=\"total\">Total Ôé¼</option>\r\n          </select>\r\n        </div>\r\n\r\n        {/* BULK ACTIONS */}\r\n        {selectedIds.size > 0 && (\r\n          <div className=\"flex gap-2 pt-2 border-t\">\r\n            <button\r\n              onClick={handleBulkExport}\r\n              className=\"px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600\"\r\n            >\r\n              Exporter ({selectedIds.size})\r\n            </button>\r\n            <button\r\n              onClick={handleBulkDelete}\r\n              className=\"px-4 py-2 bg-red-500 text-white rounded hover:bg-red-600\"\r\n            >\r\n              Supprimer\r\n            </button>\r\n          </div>\r\n        )}\r\n      </div>\r\n\r\n      {/* RESULTS COUNT */}\r\n      <div className=\"text-sm text-gray-600 dark:text-gray-400\">\r\n        {filtered.length} document{filtered.length !== 1 ? \"s\" : \"\"} trouv├®\r\n        {filtered.length !== 1 ? \"s\" : \"\"}\r\n      </div>\r\n\r\n      {/* TABLE */}\r\n      <div className=\"overflow-x-auto bg-white dark:bg-gray-800 rounded-lg shadow\">\r\n        {isSyncing ? (\r\n          <div className=\"divide-y divide-gray-100 dark:divide-gray-800\">\r\n            {[...Array(6)].map((_, i) => (\r\n              <TableRowSkeleton key={i} />\r\n            ))}\r\n          </div>\r\n        ) : filtered.length === 0 ? (\r\n          <div className=\"p-8 text-center text-gray-500\">\r\n            Aucun document trouv├®\r\n          </div>\r\n        ) : (\r\n          <table className=\"w-full text-sm\">\r\n            <thead className=\"bg-gray-100 dark:bg-gray-700 border-b\">\r\n              <tr>\r\n                <th className=\"px-4 py-3 text-left w-12\">\r\n                  <input\r\n                    type=\"checkbox\"\r\n                    checked={\r\n                      selectedIds.size === filtered.length &&\r\n                      filtered.length > 0\r\n                    }\r\n                    onChange={(e: React.ChangeEvent<HTMLInputElement>) => {\r\n                      if (e.target.checked) {\r\n                        setSelectedIds(new Set(filtered.map((i) => i.id)));\r\n                      } else {\r\n                        setSelectedIds(new Set());\r\n                      }\r\n                    }}\r\n                    className=\"cursor-pointer\"\r\n                    title=\"S├®lectionner/d├®s├®lectionner tous les documents\"\r\n                  />\r\n                </th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">Num├®ro</th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">Type</th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">Client</th>\r\n                <th className=\"px-4 py-3 text-right font-semibold\">Total</th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">Statut</th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">├ëch├®ance</th>\r\n                <th className=\"px-4 py-3 text-left font-semibold\">Date</th>\r\n                <th className=\"px-4 py-3 text-center font-semibold\">Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              {filtered.map((inv) => {\r\n                const client = clients.find((c) => c.id === inv.clientId);\r\n                const isOverdue =\r\n                  inv.type === \"invoice\" &&\r\n                  inv.status !== InvoiceStatus.PAID &&\r\n                  inv.dueDate &&\r\n                  new Date(inv.dueDate) < new Date();\r\n                const isUrgent =\r\n                  inv.type === \"invoice\" &&\r\n                  inv.status !== InvoiceStatus.PAID &&\r\n                  inv.dueDate &&\r\n                  !isOverdue &&\r\n                  new Date