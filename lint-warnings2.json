e) => setCategoryFilter(e.target.value)}\r\n                  className=\"bg-transparent text-xs font-bold text-brand-900 outline-none cursor-pointer uppercase tracking-wider\"\r\n                >\r\n                  <option value=\"\">Cat├®gories</option>\r\n                  {expenseCategories.map((cat) => (\r\n                    <option key={cat} value={cat}>\r\n                      {cat}\r\n                    </option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n              <div className=\"flex items-center gap-2 bg-white px-4 py-2 border border-brand-100 rounded-2xl shadow-sm\">\r\n                <DollarSign size={14} className=\"text-brand-400\" />\r\n                <input\r\n                  type=\"number\"\r\n                  placeholder=\"Min\"\r\n                  title=\"Montant minimum\"\r\n                  className=\"w-16 bg-transparent text-xs font-bold text-brand-900 outline-none\"\r\n                  value={minAmount}\r\n                  onChange={(e) => setMinAmount(e.target.value)}\r\n                />\r\n                <span className=\"text-brand-300\">-</span>\r\n                <input\r\n                  type=\"number\"\r\n                  placeholder=\"Max\"\r\n                  title=\"Montant maximum\"\r\n                  className=\"w-16 bg-transparent text-xs font-bold text-brand-900 outline-none\"\r\n                  value={maxAmount}\r\n                  onChange={(e) => setMaxAmount(e.target.value)}\r\n                />\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"flex gap-3 w-full sm:w-auto\">\r\n              {selectedExpenses.length > 0 && (\r\n                <button\r\n                  onClick={handleBulkDelete}\r\n                  className=\"flex-1 sm:flex-none bg-red-50 hover:bg-red-100 text-red-600 border border-red-100 px-5 py-3 rounded-2xl flex items-center justify-center gap-2 transition-all text-[10px] font-bold uppercase trac