# =============================================================================
# .env.example — Variables d'environnement pour la stack VPS
# Copier ce fichier en .env et remplir toutes les valeurs avant déploiement
# IMPORTANT : Ne jamais committer le fichier .env dans git !
# =============================================================================

# --- Domaine principal ---
DOMAIN=mon-domaine.com

# --- Let's Encrypt (email pour les alertes d'expiration) ---
ACME_EMAIL=admin@mon-domaine.com

# --- Traefik Dashboard (basic auth bcrypt) ---
# Générer avec : echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Image Docker de l'application ---
REGISTRY=ghcr.io
IMAGE_NAME=mon-org/mon-app
IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=appuser
# Générer avec : openssl rand -hex 32
POSTGRES_PASSWORD=CHANGER_CE_MOT_DE_PASSE_FORT
POSTGRES_DB=appdb

# --- Redis ---
# Générer avec : openssl rand -hex 32
REDIS_PASSWORD=CHANGER_CE_MOT_DE_PASSE_FORT

# --- NextAuth.js ---
NEXTAUTH_URL=https://mon-domaine.com
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=CHANGER_CE_SECRET_FORT

# --- Open WebUI (Ollama) ---
# Générer avec : openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGER_CE_SECRET_FORT
