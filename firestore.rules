rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // This security rules file assumes the following data structures:
    //
    // Collection: clients, suppliers, products, expenses, invoices
    // Document ID: [id]
    // Fields:
    //   - id: string (required)
    //   - uid: string (required) - ID of the owner
    //   - ... other fields
    //
    // Collection: profiles
    // Document ID: [userId]
    // Fields:
    //   - uid: string (required)
    //   - companyName: string
    //   - ... other fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "carpentier.thomas.02@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidClient(data) {
      return data.id is string && data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.uid == request.auth.uid;
    }

    function isValidSupplier(data) {
      return data.id is string && data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.id is string && data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.uid == request.auth.uid;
    }

    function isValidExpense(data) {
      return data.id is string && data.amount is number && data.uid == request.auth.uid;
    }

    function isValidInvoice(data) {
      return data.id is string && data.number is string && data.total is number && data.uid == request.auth.uid;
    }

    function isValidEmail(data) {
      return data.id is string && data.to is string && data.subject is string && data.uid == request.auth.uid;
    }

    function isValidEmailTemplate(data) {
      return data.id is string && data.name is string && data.subject is string && data.uid == request.auth.uid;
    }

    function isValidCalendarEvent(data) {
      return data.id is string && data.title is string && data.start is string && data.uid == request.auth.uid;
    }

    function isValidProfile(data) {
      return data.companyName is string && data.companyName.size() > 0 && data.uid == request.auth.uid &&
             (!('activityType' in data) || data.activityType in ['SERVICE_BNC', 'SERVICE_BIC', 'SALE', 'LIBERAL']) &&
             (!('isAcreBeneficiary' in data) || data.isAcreBeneficiary is bool) &&
             (!('vatThresholdAlert' in data) || data.vatThresholdAlert is bool) &&
             (!('revenueThresholdAlert' in data) || data.revenueThresholdAlert is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /clients/{clientId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidClient(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidClient(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSupplier(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /products/{productId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidProduct(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidExpense(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidInvoice(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidInvoice(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /emails/{emailId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidEmail(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidEmail(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /emailTemplates/{templateId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidEmailTemplate(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidEmailTemplate(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCalendarEvent(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidCalendarEvent(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidProfile(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
