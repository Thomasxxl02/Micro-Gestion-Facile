{
  "name": "micro-gestion-facile",
  "version": "1.0.0",
  "description": "Progressive Web App (PWA) for complete management of French micro-entrepreneurs - Invoices, clients, suppliers, accounting and fiscal",
  "keywords": [
    "micro-business",
    "invoices",
    "accounting",
    "management",
    "pwa",
    "react",
    "typescript",
    "firebase",
    "french"
  ],
  "author": "Thomas",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Thomasxxl02/Micro-Gestion-Facile.git"
  },
  "homepage": "https://github.com/Thomasxxl02/Micro-Gestion-Facile",
  "bugs": {
    "url": "https://github.com/Thomasxxl02/Micro-Gestion-Facile/issues"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "type-check": "tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo",
    "type-check:fresh": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "eslint src --fix --report-unused-disable-directives",
    "lint:spell": "cspell --config .cspellrc.json \"src/**/*.{ts,tsx}\" \"tsconfig.json\" \"vite.config.ts\" \"vitest.config.ts\" \"eslint.config.js\"",
    "lint:spell:fix": "cspell --config .cspellrc.json \"src/**/*.{ts,tsx}\" \"tsconfig.json\" \"vite.config.ts\" \"vitest.config.ts\" \"eslint.config.js\" --unique --words-only",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "validate": "npm run type-check && npm run lint && npm run test:coverage",
    "ci": "npm run format:check && npm run type-check:fresh && npm run lint && vitest run --coverage",
    "audit:prod": "npm audit --omit=dev",
    "format": "prettier --write \".\" --cache",
    "format:check": "prettier --check \".\" --cache"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.48.0",
    "@tanstack/react-query": "^5.96.2",
    "decimal.js": "^10.6.0",
    "dexie": "^4.4.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "firebase": "^12.11.0",
    "immer": "^11.1.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@cspell/dict-fr-fr": "^2.3.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^25.5.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/expect": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "cspell": "^10.0.0",
    "cssnano": "^7.1.4",
    "electron-to-chromium": "^1.5.331",
    "eslint": "^10.2.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.3.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "smol-toml": "^1.6.1",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "undici": "^8.0.2",
    "vite": "^8.0.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
